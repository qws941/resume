{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "checkJs": false,
    "allowJs": true,
    "noEmit": true,
    "strict": false,
    "strictNullChecks": false,
    "strictFunctionTypes": true,
    "noImplicitAny": false,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["apps/portfolio/lib/*"],
      "@tests/*": ["tests/*"]
    },
    "types": ["node", "jest", "@playwright/test"]
  },
  "include": [
    "packages/cli/**/*.js",
    "apps/portfolio/lib/**/*.js",
    "apps/portfolio/src/**/*.js",
    "apps/job-server/src/**/*.js",
    "packages/data/**/*.js",
    "tools/scripts/**/*.js"
  ],
  "exclude": [
    "**/node_modules/**",
    "coverage",
    "playwright-report",
    "test-results",
    "apps/portfolio/worker.js",
    "apps/portfolio/sw.js",
    "apps/portfolio/sentry-config.js",
    "apps/portfolio/src/scripts/modules/**",
    "apps/job-server/platforms/**",
    "tests/**",
    ".wrangler"
  ]
}
